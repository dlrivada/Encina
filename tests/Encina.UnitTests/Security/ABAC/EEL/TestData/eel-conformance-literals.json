{
  "category": "literals",
  "tests": [
    {
      "name": "true_literal",
      "expression": "true",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "false_literal",
      "expression": "false",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": false
    },
    {
      "name": "integer_equality_true",
      "expression": "1 == 1",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "integer_equality_false",
      "expression": "1 == 2",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": false
    },
    {
      "name": "string_equality_true",
      "expression": "\"hello\" == \"hello\"",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "string_equality_false",
      "expression": "\"hello\" == \"world\"",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": false
    },
    {
      "name": "double_comparison",
      "expression": "3.14 > 2.71",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "negated_true",
      "expression": "!false",
      "globals": { "user": {}, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    }
  ]
}
