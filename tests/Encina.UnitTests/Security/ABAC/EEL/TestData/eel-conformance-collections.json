{
  "category": "collections",
  "tests": [
    {
      "name": "list_contains_true",
      "expression": "((IEnumerable<object>)user.roles).Cast<string>().Contains(\"admin\")",
      "globals": { "user": { "roles": ["admin", "user"] }, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "list_contains_false",
      "expression": "((IEnumerable<object>)user.roles).Cast<string>().Contains(\"superadmin\")",
      "globals": { "user": { "roles": ["admin", "user"] }, "resource": {}, "environment": {}, "action": {} },
      "expected": false
    }
  ]
}
