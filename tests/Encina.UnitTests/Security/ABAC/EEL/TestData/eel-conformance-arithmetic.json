{
  "category": "arithmetic",
  "tests": [
    {
      "name": "addition_comparison",
      "expression": "user.age + 1 > 18",
      "globals": { "user": { "age": 18 }, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "subtraction_comparison",
      "expression": "resource.amount - 100 >= 0",
      "globals": { "user": {}, "resource": { "amount": 150 }, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "multiplication_comparison",
      "expression": "resource.price * resource.quantity > 1000",
      "globals": { "user": {}, "resource": { "price": 50, "quantity": 25 }, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "division_comparison",
      "expression": "resource.total / resource.count < 100",
      "globals": { "user": {}, "resource": { "total": 300, "count": 5 }, "environment": {}, "action": {} },
      "expected": true
    },
    {
      "name": "modulo_comparison",
      "expression": "user.id % 2 == 0",
      "globals": { "user": { "id": 42 }, "resource": {}, "environment": {}, "action": {} },
      "expected": true
    }
  ]
}
