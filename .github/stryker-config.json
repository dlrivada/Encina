{
  "$schema": "https://stryker-mutator.io/schema/stryker.schema.json",
  "stryker-config": {
    "solution": "Encina.slnx",
    "project": "src/Encina/Encina.csproj",
    "test-projects": [
      "tests/Encina.UnitTests/Encina.UnitTests.csproj",
      "tests/Encina.PropertyTests/Encina.PropertyTests.csproj",
      "tests/Encina.ContractTests/Encina.ContractTests.csproj"
    ],
    "test-case-filter": "FullyQualifiedName~Encina.UnitTests|FullyQualifiedName~Encina.PropertyTests|FullyQualifiedName~Encina.ContractTests",
    "reporters": [
      "progress",
      "json",
      "cleartext"
    ],
    "concurrency": 2,
    "break-on-initial-test-failure": true,
    "coverage-analysis": "off",
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 60
    },
    "mutate": [
      "**/Sharding/Migrations/Strategies/*.cs"
    ]
  }
}
