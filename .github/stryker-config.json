{
  "$schema": "https://stryker-mutator.io/schema/stryker.schema.json",
  "stryker-config": {
    "solution": "Encina.slnx",
    "project": "src/Encina/Encina.csproj",
    "test-projects": [
      "tests/Encina.UnitTests/Encina.UnitTests.csproj",
      "tests/Encina.PropertyTests/Encina.PropertyTests.csproj",
      "tests/Encina.ContractTests/Encina.ContractTests.csproj"
    ],
    "reporters": [
      "progress",
      "json",
      "cleartext"
    ],
    "concurrency": 8,
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 60
    },
    "mutate": [
      "src/Encina/**/*.cs",
      "!src/Encina/**/Log.cs",
      "!src/Encina/**/LogMessages.cs",
      "!src/Encina/**/Diagnostics/*ActivitySource.cs",
      "!src/Encina/**/Diagnostics/*Metrics.cs",
      "!src/Encina/**/*Errors.cs",
      "!src/Encina/**/*Constants.cs"
    ]
  }
}
