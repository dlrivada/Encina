<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackageId>Encina.Security.ABAC.Cli</PackageId>
    <Description>CLI tool for validating EEL (Encina Expression Language) expressions in assemblies. Scans for [RequireCondition] attributes, compiles expressions, and outputs results in human-readable or SARIF format for CI/CD integration.</Description>
    <PackageTags>encina;cli;abac;eel;validation;dotnet-tool</PackageTags>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>encina-eel</ToolCommandName>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Encina.Security.ABAC\Encina.Security.ABAC.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Spectre.Console" />
  </ItemGroup>

</Project>
