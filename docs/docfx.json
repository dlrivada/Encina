{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "includePrivateMembers": false,
      "includeExplicitInterfaceImplementations": false,
      "filter": "filterConfig.yml",
      "memberLayout": "separatePages",
      "namespaceLayout": "nested"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.yml"
        ],
        "src": "api",
        "dest": "."
      },
      {
        "files": [
          "index.md"
        ],
        "src": "_api-landing",
        "dest": "."
      }
    ],
    "output": "_api-build",
    "template": [
      "default",
      "modern",
      "_docfx-template"
    ],
    "globalMetadata": {
      "_appName": "Encina",
      "_appTitle": "Encina API Reference",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/dlrivada/Encina",
        "branch": "main"
      },
      "_gitUrlPattern": "github",
      "_disableContribution": false,
      "_disableBreadcrumb": false,
      "pdf": false
    },
    "sitemap": {
      "baseUrl": "https://dlrivada.github.io/Encina/api/"
    }
  }
}
